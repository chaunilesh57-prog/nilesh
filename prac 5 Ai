Develop an elementary chatbot for any suitable customer interaction application. 


import datetime

def greet():
    print("🤖 ChatBot: Hello! Welcome to Customer Support.")
    print("🤖 ChatBot: How can I help you today?")
    print("Type 'exit' to end the chat.\n")

def get_time():
    now = datetime.datetime.now()
    return now.strftime("%H:%M:%S")

def chatbot_response(user_input):
    user_input = user_input.lower()

    # Greetings
    if "hello" in user_input or "hi" in user_input:
        return "Hello! How can I assist you today?"

    # Product Inquiry
    elif "product" in user_input:
        return "We offer electronics, clothing, and accessories. What are you looking for?"

    # Price Inquiry
    elif "price" in user_input or "cost" in user_input:
        return "Prices vary depending on the product. Please specify the item."

    # Order Status
    elif "order" in user_input and "status" in user_input:
        return "Please provide your Order ID to check the status."

    # Delivery
    elif "delivery" in user_input:
        return "Delivery usually takes 3-5 business days."

    # Return Policy
    elif "return" in user_input:
        return "You can return products within 7 days of delivery."

    # Time query
    elif "time" in user_input:
        return f"Current time is {get_time()}"

    # Thanks
    elif "thank" in user_input:
        return "You're welcome! 😊"

    # Exit
    elif "exit" in user_input:
        return "exit"

    # Default
    else:
        return "Sorry, I didn't understand that. Can you rephrase?"

def run_chatbot():
    greet()

    while True:
        user_input = input("You: ")
        response = chatbot_response(user_input)

        if response == "exit":
            print("🤖 ChatBot: Thank you for contacting us. Have a great day!")
            break

        print("🤖 ChatBot:", response)

# Run the chatbot
run_chatbot()
